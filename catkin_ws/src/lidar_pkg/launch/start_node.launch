<launch>
    <include file="$(find ouster_ros)/launch/driver.launch">
        <arg name="sensor_hostname" value="10.42.0.185"/>
        <arg name="viz" value="false"/>
    </include>

    <node
        pkg="lidar_pkg"
        type="lidar_node.py"
        name="lidar_node"
        output="screen"
    />
</launch>